---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="API Client - Mini Postman">
  <div class="flex h-[calc(100vh-8rem)]" id="app-root">
    <aside class="hidden md:block w-64 shrink-0">
      <div class="h-full bg-gray-100 border-r border-gray-200 p-4">
        <button class="w-full mb-4 px-3 py-2 bg-indigo-600 text-white rounded text-sm font-medium hover:bg-indigo-700">
          + New Request
        </button>
        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">Recent</h3>
          <p class="text-sm text-gray-400">No requests yet</p>
        </div>
      </div>
    </aside>

    <div class="flex-1 flex flex-col">
      <div class="p-4 bg-white border-b border-gray-200">
        <div class="flex gap-2 mb-3">
          <select class="px-3 py-2 border border-gray-300 rounded text-sm font-medium">
            <option>GET</option>
            <option>POST</option>
            <option>PUT</option>
            <option>PATCH</option>
            <option>DELETE</option>
          </select>
          <input type="text" placeholder="Enter URL..." class="flex-1 px-3 py-2 border border-gray-300 rounded text-sm" />
          <button class="px-4 py-2 bg-green-600 text-white rounded text-sm font-medium hover:bg-green-700">
            Send
          </button>
          <button class="px-4 py-2 bg-indigo-600 text-white rounded text-sm font-medium hover:bg-indigo-700">
            Save
          </button>
        </div>
      </div>

      <div class="flex-1 bg-gray-50 p-4 overflow-auto">
        <div class="text-center text-gray-400 mt-8">
          Enter a URL and click Send to make a request
        </div>
      </div>
    </div>
  </div>
</BaseLayout>